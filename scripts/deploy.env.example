# scripts/deploy.env — 本机部署凭据 (gitignored, 真实值填这个文件)
# 复制本文件为 scripts/deploy.env 后填实际值,deploy.sh 会 source 它。
#
# ⚠️ 永不入 git (匹配 .gitignore 的 .env* 规则)
# ⚠️ 真实 ECS_IP / SSH_KEY_PATH 不要写进任何 md / commit / chat

# ECS 公网 IP
ECS_IP=

# SSH 私钥路径 (本地文件, chmod 600)
SSH_KEY_PATH=

# ECS 上项目路径 (默认 /opt/ibiren,一般不用改)
ECS_PROJECT_DIR=/opt/ibiren

# ECS 上 systemd 服务名 (ibiren-api)
ECS_API_SERVICE=ibiren-api

# ECS 上 web/admin 静态文件目录 (给 nginx 用)
ECS_WEB_DIR=/var/www/ibiren/web
ECS_ADMIN_DIR=/var/www/ibiren/admin

# 本地相对路径 (相对项目根)
LOCAL_PROJECT_DIR=.

# 要部署的三端 (空格分隔, 一般不动)
DEPLOY_TARGETS=api web admin

# smoke 测试端口 (一般不动)
SMOKE_WEB_PORT=8080
SMOKE_ADMIN_PORT=8081
SMOKE_API_PORT=3100
