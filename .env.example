# =============================================================
# ibi.ren 环境变量样例 —— 复制为 .env.local 后填入实际值
# =============================================================

# ---------- 公共 ----------
NODE_ENV=development
APP_BASE_URL=http://localhost:5173
API_BASE_URL=http://localhost:3000

# ---------- 数据库 (Aliyun RDS MySQL 8) ----------
# 本地开发: ssl 参数可省略
DATABASE_URL="mysql://ibi_ren:CHANGE_ME@127.0.0.1:3306/ibi_ren?charset=utf8mb4&parseTime=True&loc=Local"
# 生产 (阿里云 RDS, 已开 SSL): 必须含 ssl-mode=REQUIRED
# DATABASE_URL="mysql://ibi_user01:CHANGE_ME@rm-uf6px83tcbt52z3xc.mysql.rds.aliyuncs.com:3306/ibi_ren?ssl-mode=REQUIRED&charset=utf8mb4&parseTime=True&loc=Local"

# ---------- Redis (Aliyun Redis 7) ----------
REDIS_URL="redis://127.0.0.1:6379"

# ---------- JWT ----------
JWT_ACCESS_SECRET="change-me-access-32chars-minimum-xxxxxxxx"
JWT_ACCESS_TTL="15m"
JWT_REFRESH_SECRET="change-me-refresh-32chars-minimum-xxxxxxx"
JWT_REFRESH_TTL="30d"

# ---------- 阿里云 OSS ----------
OSS_REGION="oss-cn-hangzhou"
OSS_ACCESS_KEY_ID="LTAIxxxxxxxxxxxxx"
OSS_ACCESS_KEY_SECRET="xxxxxxxxxxxxxxxxxxxxxxxx"
OSS_BUCKET_PUBLIC="ibi-ren-dev-public"
OSS_BUCKET_PRIVATE="ibi-ren-dev-private"
OSS_BUCKET_CONTRACTS="ibi-ren-dev-contracts"
OSS_CALLBACK_SECRET="oss-callback-secret-change-me"

# ---------- 阿里云内容安全 (Green) ----------
ALIYUN_GREEN_ACCESS_KEY_ID=""
ALIYUN_GREEN_ACCESS_KEY_SECRET=""
ALIYUN_GREEN_REGION="cn-shanghai"
MODERATION_DRIVER="real"

# ---------- 阿里云百炼 (DashScope — image gen + vision, #30.6+) ----------
# Track B 反推参考图(Qwen-VL) + 现有 image gen(Wan2.7)共用
# 留空 = 端点返 503(不会静默失败,Joi 校验保底)
DASHSCOPE_API_KEY=""
DASHSCOPE_MODEL="wan2.7-image-pro"
DASHSCOPE_VL_MODEL="qwen-vl-plus"

# ---------- LLM (MiniMax M3, Anthropic 协议兼容, #30.6) ----------
# 不入库, 复制到 .env.local 后填实际值
MINIMAX_API_KEY="sk-api-PLACEHOLDER"
MINIMAX_BASE_URL="https://api.minimaxi.com"
MINIMAX_MODEL="claude-sonnet-4-6"

# ---------- 区块链 / 电子签 / 支付 (MVP 用 mock) ----------
BLOCKCHAIN_DRIVER="mock"
ESIGN_DRIVER="mock"
PAYMENT_DRIVER="mock"
KYC_DRIVER="mock"

# ---------- 水印 ----------
WATERMARK_DRIVER="mock"

# ---------- 缩略图域名 (前端用) ----------
VITE_OSS_PUBLIC_BASE="https://ibi-ren-dev-public.oss-cn-hangzhou.aliyuncs.com"

# ---------- 日志 ----------
LOG_LEVEL="info"
SENTRY_DSN=""

# ---------- 创世管理员 ----------
SEED_ADMIN_EMAIL="admin@ibi.ren"
SEED_ADMIN_PASSWORD="ChangeMe!2026"