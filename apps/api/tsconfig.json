{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    "module": "commonjs",
    "moduleResolution": "node",
    "isolatedModules": false,
    "verbatimModuleSyntax": false,
    "paths": {
      "@ibi-ren/shared-contracts": ["../../packages/shared-contracts/src"],
      "@ibi-ren/shared-contracts/*": ["../../packages/shared-contracts/src/*"]
    }
  },
  "include": ["src/**/*", "prisma/**/*.ts"],
  "exclude": ["node_modules", "dist", "test"]
}