# apps/api/.env.example — env 模板 (git tracked)
# 真实 .env 在 .gitignore 里,本机 + ECS 各自填值

NODE_ENV=development
APP_BASE_URL=http://localhost:3000
API_BASE_URL=http://localhost:3100

DATABASE_URL=PLACEHOLDER_OVERRIDE_IN_LOCAL_ENV
JWT_ACCESS_SECRET=change-me-at-least-32-chars
JWT_ACCESS_TTL=900
JWT_REFRESH_SECRET=change-me-at-least-32-chars
JWT_REFRESH_TTL=2592000

OSS_REGION=oss-cn-hangzhou
OSS_ACCESS_KEY_ID=LTAI...
OSS_ACCESS_KEY_SECRET=...
OSS_BUCKET_PUBLIC=ibi-ren-public
OSS_BUCKET_PRIVATE=ibi-ren-private
OSS_BUCKET_CONTRACTS=ibi-ren-contracts
OSS_CALLBACK_SECRET=...

# KYC 实名核身 — KYC_DRIVER 切换 mock|aliyun
KYC_DRIVER=mock

# OCR 营业执照 — OCR_DRIVER 切换 mock|aliyun
OCR_DRIVER=mock

# 当 KYC_DRIVER=aliyun 时,以下必填:
ALIYUN_KYC_ACCESS_KEY_ID=
ALIYUN_KYC_ACCESS_KEY_SECRET=
ALIYUN_KYC_REGION=cn-shanghai
ALIYUN_KYC_BIZTYPE=RPBasicTest
# 阿里云控制台创建的"实人认证"场景 bizType 名称
# (不是数字 SCENE_ID — 老 id_verify 服务的 SCENE_ID=1000019263 不能直接用)

# 当 OCR_DRIVER=aliyun 时,以下必填:
ALIYUN_OCR_ACCESS_KEY_ID=
ALIYUN_OCR_ACCESS_KEY_SECRET=
ALIYUN_OCR_REGION=cn-hangzhou

# ===================== W3 W1: 多通道登录 =====================

# SMS 短信 (国内手机号验证码)
# SMS_DRIVER=mock 时 SmsService 在后端日志打印 code (SMS_LOG_CODE=true 才看得到明文)
# SMS_DRIVER=aliyun 时需填下面 4 个 ALIYUN_SMS_* + 阿里云短信签名/模板审核通过
SMS_DRIVER=mock
SMS_LOG_CODE=true
SMS_CODE_TTL_SECONDS=300
SMS_CODE_LENGTH=6
SMS_THROTTLE_SECONDS=60
SMS_MAX_DAILY_PER_PHONE=10
SMS_MAX_ATTEMPTS=5
ALIYUN_SMS_ACCESS_KEY_ID=
ALIYUN_SMS_ACCESS_KEY_SECRET=
ALIYUN_SMS_SIGN_NAME=ibi.ren
ALIYUN_SMS_TEMPLATE_CODE_LOGIN=

# 微信开放平台 OAuth (网站应用, snsapi_login 扫码)
# 真 driver 需 ICP 备案完成 + redirect_uri 已在开放平台后台配置
# 当前默认 mock,前端用 mock 跑通端到端
WECHAT_OAUTH_DRIVER=mock
WECHAT_OAUTH_APP_ID=
WECHAT_OAUTH_APP_SECRET=
WECHAT_OAUTH_REDIRECT_URI=https://ibi.ren/api/v1/auth/wechat/callback

# 手机号格式校验 (国内 11 位)
PHONE_REGEX=^1[3-9]\d{9}$