# 本地 dev: Vite 自动 proxy /api → http://localhost:3100 (见 vite.config.ts)
# /ips/ 也由 Vite proxy 到 OSS, 不需要这里配
VITE_API_BASE_URL=http://localhost:3000
# 空 = 相对路径 /ips/..., 走 nginx (prod) / Vite proxy (dev) → OSS
VITE_OSS_PUBLIC_BASE=
VITE_APP_TITLE="ibi.ren · Idol Bank IP"
# Blueprint Wizard 生产开关 (Phase C R2) — 默认 ON
# 测试 kill switch 时改 false,验证 /creator/blueprint/* 自动跳 /creator
VITE_BLUEPRINT_WIZARD_ENABLED=true