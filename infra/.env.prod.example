# =============================================================
# ibi.ren · 生产环境变量样例 (阿里云 ECS 单机部署)
# 复制: cp .env.prod.example .env && nano .env
# =============================================================

NODE_ENV=production
APP_BASE_URL=https://ibi.ren
API_BASE_URL=https://api.ibi.ren

# ---------- 数据库 (阿里云 RDS MySQL 8) ----------
# 注意: SSL 已开 → 必须 ssl-mode=REQUIRED
DATABASE_URL="mysql://ibi_user01:CHANGE_ME@rm-uf6px83tcbt52z3xc.mysql.rds.aliyuncs.com:3306/ibi_ren?ssl-mode=REQUIRED&charset=utf8mb4&parseTime=True&loc=Local"

# ---------- Redis (阿里云 Redis 7) ----------
REDIS_URL="redis://:PASSWORD@r-xxxx.redis.rds.aliyuncs.com:6379/0"

# ---------- JWT (32 字节以上随机串) ----------
JWT_ACCESS_SECRET="REPLACE_WITH_openssl_rand_-base64_48"
JWT_ACCESS_TTL="15m"
JWT_REFRESH_SECRET="REPLACE_WITH_openssl_rand_-base64_48"
JWT_REFRESH_TTL="30d"

# ---------- 阿里云 OSS (cn-shanghai) ----------
OSS_REGION="oss-cn-shanghai"
OSS_ACCESS_KEY_ID="LTAIxxxxxxxxxxxxx"
OSS_ACCESS_KEY_SECRET="xxxxxxxxxxxxxxxxxxxxxxxx"
OSS_BUCKET_PUBLIC="ibi-public"
OSS_BUCKET_PRIVATE="ibi-private"
OSS_BUCKET_CONTRACTS="ibi-contracts"
OSS_CALLBACK_SECRET="oss-callback-secret-32bytes-random"

# ---------- 内容安全 (Aliyun Green) ----------
ALIYUN_GREEN_ACCESS_KEY_ID=""
ALIYUN_GREEN_ACCESS_KEY_SECRET=""
ALIYUN_GREEN_REGION="cn-shanghai"
MODERATION_DRIVER="real"

# ---------- 外部服务 (MVP 用 mock) ----------
BLOCKCHAIN_DRIVER="mock"
ESIGN_DRIVER="mock"
PAYMENT_DRIVER="mock"
KYC_DRIVER="mock"
WATERMARK_DRIVER="mock"

# ---------- 监控 ----------
LOG_LEVEL="info"
SENTRY_DSN=""

# ---------- 创世管理员 ----------
SEED_ADMIN_EMAIL="admin@ibi.ren"
SEED_ADMIN_PASSWORD="ChangeMe!2026"

# ---------- 端口 ----------
API_PORT=3100
